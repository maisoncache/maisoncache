# ── Notion ──────────────────────────────────────────────────────────────────
# Notion integration token (Settings → Connections → Develop or manage integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID of the Content Hub database (from the database URL: notion.so/{workspace}/{DATABASE_ID}?v=...)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Name of the Status property in your Notion database (usually "Status")
NOTION_STATUS_PROPERTY=Status
# Name of the Title property in your Notion database (usually "Title" or "Name")
NOTION_TITLE_PROPERTY=Title
# Name of the Tags/Pillar property (used to set Ghost tags)
NOTION_TAGS_PROPERTY=Tags

# ── Ghost ────────────────────────────────────────────────────────────────────
# Your Ghost site URL (no trailing slash)
GHOST_URL=https://maison-cache.ghost.io
# Admin API key from Settings → Integrations → Custom Integration → Admin API Key
# Format: {id}:{secret}
GHOST_ADMIN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Content API key from Settings → Integrations → Custom Integration → Content API Key
GHOST_CONTENT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret — set this when you create the webhook in Ghost
# Settings → Integrations → Custom Integration → Add webhook → Secret
GHOST_WEBHOOK_SECRET=your_webhook_secret_here

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with 'repo' scope (or fine-grained with contents:write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Repo to commit HTML changes to
GITHUB_REPO=maisoncache/maisoncache
# Branch GitHub Pages deploys from (usually 'main')
GITHUB_BRANCH=main

# ── Webhook server ───────────────────────────────────────────────────────────
# Port for the Ghost webhook receiver to listen on
WEBHOOK_PORT=3000

# ── Notifications ────────────────────────────────────────────────────────────
# Discord webhook URL (or any endpoint that accepts POST with { "content": "..." })
# Leave blank to disable notifications
NOTIFICATION_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url
